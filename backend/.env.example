# Django core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
POSTGRES_DB=hrrecruit_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Password reset links
FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/forgot-password

# Local development default: prints emails in the Django server console.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@hrrecruit.local

# To receive real emails in an inbox, use SMTP settings like these.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-smtp-username@example.com
# EMAIL_HOST_PASSWORD=your-smtp-app-password
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=your-smtp-username@example.com

# Optional SendGrid HTTP API support; leave blank for console/SMTP email backend.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
